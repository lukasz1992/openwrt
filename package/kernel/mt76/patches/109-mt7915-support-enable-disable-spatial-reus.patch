From: Howard Hsu <howard-yh.hsu@mediatek.com>
Date: Tue, 5 Sep 2023 20:17:19 +0800
Subject: [PATCH 1036/1052] wifi: mt76: mt7915: support enable/disable spatial
 reuse through debugfs

Signed-off-by: Howard Hsu <howard-yh.hsu@mediatek.com>
---
 mt7915/mcu.c         |  3 +--
 mt7915/mt7915.h      |  1 +
 mt7915/debugfs.c     | 12 ++++++++++++
 3 files changed, 14 insertions(+), 2 deletions(-)

--- a/mt7915/mcu.c
+++ b/mt7915/mcu.c
@@ -3561,8 +3561,7 @@ int mt7915_mcu_set_txbf(struct mt7915_de
 				 sizeof(req), true);
 }
 
-static int
-mt7915_mcu_enable_obss_spr(struct mt7915_phy *phy, u8 action, u8 val)
+int mt7915_mcu_enable_obss_spr(struct mt7915_phy *phy, u8 action, u8 val)
 {
 	struct mt7915_dev *dev = phy->dev;
 	struct mt7915_mcu_sr_ctrl req = {
--- a/mt7915/mt7915.h
+++ b/mt7915/mt7915.h
@@ -514,6 +514,7 @@ int mt7915_mcu_fw_log_2_host(struct mt79
 int mt7915_mcu_fw_dbg_ctrl(struct mt7915_dev *dev, u32 module, u8 level);
 void mt7915_mcu_rx_event(struct mt7915_dev *dev, struct sk_buff *skb);
 void mt7915_mcu_exit(struct mt7915_dev *dev);
+int mt7915_mcu_enable_obss_spr(struct mt7915_phy *phy, u8 action, u8 val);
 
 static inline u16 mt7915_wtbl_size(struct mt7915_dev *dev)
 {
--- a/mt7915/debugfs.c
+++ b/mt7915/debugfs.c
@@ -1236,6 +1236,17 @@ exit:
 DEFINE_DEBUGFS_ATTRIBUTE(fops_muru_onoff, mt7915_muru_onoff_get,
                        mt7915_muru_onoff_set, "%llx\n");
 
+static int
+mt7915_sr_enable_set(void *data, u64 val)
+{
+	struct mt7915_phy *phy = data;
+
+	return mt7915_mcu_enable_obss_spr(phy, SPR_ENABLE, val);
+}
+
+DEFINE_DEBUGFS_ATTRIBUTE(fops_sr_enable, NULL,
+			 mt7915_sr_enable_set, "%llx\n");
+
 int mt7915_init_debugfs(struct mt7915_phy *phy)
 {
 	struct mt7915_dev *dev = phy->dev;
@@ -1272,6 +1283,7 @@ int mt7915_init_debugfs(struct mt7915_ph
 	debugfs_create_u32("ignore_radar", 0600, dir,
 			   &dev->ignore_radar);
 	debugfs_create_file("muru_onoff", 0600, dir, phy, &fops_muru_onoff);
+	debugfs_create_file("sr_enable", 0200, dir, phy, &fops_sr_enable);
 
 	if (!dev->dbdc_support || phy->mt76->band_idx) {
 		debugfs_create_u32("dfs_hw_pattern", 0400, dir,
